GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Chat LLM (required) - Claude is the only supported chat LLM provider.
CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI / Gemini keys are kept ONLY for STT (Whisper) and embedding
# providers. Anthropic does not offer STT or embeddings, so these
# vendors continue to power those features when keys are present.
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# Speech-to-Text providers (Optional)
GROQ_API_KEY=your_groq_stt_key_here
DEEPGRAM_API_KEY=your_deepgram_key_here
ELEVENLABS_API_KEY=your_elevenlabs_key_here
AZURE_SPEECH_KEY=your_azure_key_here
AZURE_SPEECH_REGION=eastus
IBM_WATSON_API_KEY=your_ibm_key_here
IBM_WATSON_REGION=us-south

# Default chat model (Optional)
DEFAULT_MODEL=claude-sonnet-4-6
